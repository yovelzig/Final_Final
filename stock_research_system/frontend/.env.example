# Browser-safe (exposed to client JS via the NEXT_PUBLIC_ prefix - never
# put a secret behind this prefix).
NEXT_PUBLIC_FINQUEST_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=FinQuest

# Server-only (Next.js Route Handlers / middleware - never sent to the browser).
# The in-Docker-network hostname the Next.js server itself calls; falls
# back to NEXT_PUBLIC_FINQUEST_API_BASE_URL when unset (local dev without Docker).
FINQUEST_API_INTERNAL_URL=http://localhost:8080
FINQUEST_WEB_ORIGIN=http://localhost:3000
AUTH_COOKIE_SECURE=false
