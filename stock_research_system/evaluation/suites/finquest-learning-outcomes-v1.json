{
  "description": "Fixture definitions for application.quality_evaluation.learning_metrics unit tests - not a QualityEvaluationCase suite (learning-outcome metrics grade FinQuest's own mastery/misconception/scenario/portfolio-risk records, not a tutor/Coach response, so this file has no user_input/context_type fields).",
  "calculation_version": "learning-metrics-v1",
