networks:
  finquest-net:
    driver: bridge
    ipam:
      config:
        - subnet: 172.28.0.0/24

services:
  stock-db:
    image: timescale/timescaledb:2.17.2-pg16
    container_name: stock-db
    restart: unless-stopped
    networks: [finquest-net]
    environment:
      POSTGRES_USER: stock_user
      POSTGRES_PASSWORD: stock_password
      POSTGRES_DB: stock_research
    ports:
      - "5433:5432"
    volumes:
      - stock_db_data:/var/lib/postgresql/data
      - ./scripts/init_test_db.sql:/docker-entrypoint-initdb.d/init_test_db.sql:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U stock_user -d stock_research"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 10s

  redis:
    image: redis:7-alpine
    container_name: finquest-redis
    restart: unless-stopped
    networks: [finquest-net]
    # No host port mapping - Redis is reachable only from other
    # containers on `finquest-net`, never from the host or the public
    # internet by default.
    command: >
      redis-server
      --maxmemory 256mb
      --maxmemory-policy noeviction
      --save ""
      --appendonly no
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 5s
    # Deliberately no volume: task delivery is transient by design
    # (PostgreSQL is the durable source of truth, per README ss"Phase
    # 11" - losing in-flight Redis state at worst delays a job, it never
    # loses one, since `BackgroundJobService.create_job` durably persists
    # PENDING before ever enqueueing).

  finquest-api:
    build:
      context: .
      dockerfile: Dockerfile
      target: base
    container_name: finquest-api
    restart: unless-stopped
    networks: [finquest-net]
    depends_on:
      stock-db:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      # Uses the in-network hostname/port (5432), not the host-mapped 5433.
      DATABASE_URL: postgresql+asyncpg://stock_user:stock_password@stock-db:5432/stock_research
      AUTH_JWT_SECRET: ${AUTH_JWT_SECRET:?AUTH_JWT_SECRET must be set - see README}
      API_HOST: 0.0.0.0
      API_PORT: 8080
      # The frontend's browser-facing origin - never a wildcard, and
      # CORSMiddleware only sets Access-Control-Allow-Credentials when
      # the configured origin list excludes "*" (see api/app_factory.py).
      API_CORS_ORIGINS: ${FINQUEST_WEB_ORIGIN:-http://localhost:3000}
      # This image does not install the optional `ai_tutor` extra
      # (sentence-transformers is a large ML dependency), so the
      # network-free, deterministic embedding adapter is the default
      # here - matching TUTOR_MODEL_PROVIDER=extractive's same
      # no-model-download philosophy. A deployment wanting real
      # semantic embeddings should rebuild with the `ai` target and
      # override this to `sentence_transformer`.
      EMBEDDING_PROVIDER: ${EMBEDDING_PROVIDER:-deterministic_fake}
      FINQUEST_ENV: ${FINQUEST_ENV:-development}
      ALLOW_FAKE_EMBEDDINGS_IN_PRODUCTION: ${ALLOW_FAKE_EMBEDDINGS_IN_PRODUCTION:-false}
      REDIS_URL: redis://redis:6379/0
      CELERY_BROKER_URL: redis://redis:6379/0
      CELERY_RESULT_BACKEND: redis://redis:6379/1
      CELERY_WORKER_PREFETCH_MULTIPLIER: "1"
      CELERY_TASK_ACKS_LATE: "true"
      METRICS_ENABLED: ${METRICS_ENABLED:-true}
      READINESS_REQUIRE_WORKER: ${READINESS_REQUIRE_WORKER:-true}
      # `finquest-web` is the only other container that ever proxies
      # browser requests to this API - trusted only because it lives on
      # this same private `finquest-net` (172.28.0.0/24), never a public
      # or broad RFC1918 range.
      TRUST_FORWARDED_HEADERS: "true"
      TRUSTED_PROXY_CIDRS: "172.28.0.0/24"
      # Phase 12: LangGraph learning coach - opt-in, no separate LangGraph
      # server. Disabled by default; when enabled, the checkpointer's
      # tables must already exist (run the admin CLI's
      # `--setup-checkpointer` once - never automatic on every startup).
      LANGGRAPH_ENABLED: ${LANGGRAPH_ENABLED:-false}
      LANGGRAPH_GRAPH_VERSION: ${LANGGRAPH_GRAPH_VERSION:-learning-coach-graph-v1}
      LANGGRAPH_MAX_STEPS: ${LANGGRAPH_MAX_STEPS:-30}
      LANGGRAPH_RUN_TIMEOUT_SECONDS: ${LANGGRAPH_RUN_TIMEOUT_SECONDS:-90}
      LANGGRAPH_MAX_REPAIR_ATTEMPTS: ${LANGGRAPH_MAX_REPAIR_ATTEMPTS:-1}
      LANGGRAPH_MODEL_INTENT_CLASSIFICATION: ${LANGGRAPH_MODEL_INTENT_CLASSIFICATION:-false}
      LANGGRAPH_CHECKPOINTER_ENABLED: ${LANGGRAPH_CHECKPOINTER_ENABLED:-true}
      LANGGRAPH_THREAD_LOCK_TTL_SECONDS: ${LANGGRAPH_THREAD_LOCK_TTL_SECONDS:-120}
      LANGGRAPH_THREAD_LOCK_WAIT_SECONDS: ${LANGGRAPH_THREAD_LOCK_WAIT_SECONDS:-2}
      LANGGRAPH_MAX_CONTEXT_CHARACTERS: ${LANGGRAPH_MAX_CONTEXT_CHARACTERS:-20000}
      LANGGRAPH_MAX_STATE_LIST_ITEMS: ${LANGGRAPH_MAX_STATE_LIST_ITEMS:-50}
      LANGSMITH_TRACING: ${LANGSMITH_TRACING:-false}
      LANGSMITH_API_KEY: ${LANGSMITH_API_KEY:-}
      LANGSMITH_PROJECT: ${LANGSMITH_PROJECT:-finquest-learning-coach}
      LANGSMITH_TRACE_CONTENT: ${LANGSMITH_TRACE_CONTENT:-false}
    ports:
      - "${API_HOST_PORT:-8080}:8080"
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:8080/health"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 15s
    # Migrations are NOT run automatically - see the Dockerfile header
    # comment and the README for the explicit `alembic upgrade head` step.

  finquest-web:
    build:
      context: ./frontend
      dockerfile: Dockerfile
      args:
        # Baked into the client bundle at build time - the browser calls
        # this URL directly, so it must be reachable from the HOST
        # (never the in-Docker-network hostname).
        NEXT_PUBLIC_FINQUEST_API_BASE_URL: ${NEXT_PUBLIC_FINQUEST_API_BASE_URL:-http://localhost:8080}
        NEXT_PUBLIC_APP_NAME: FinQuest
    container_name: finquest-web
    restart: unless-stopped
    networks: [finquest-net]
    depends_on:
      finquest-api:
        condition: service_healthy
    environment:
      # Server-only: the Next.js Route Handlers running INSIDE this
      # container reach the API via the in-Docker-network hostname.
      FINQUEST_API_INTERNAL_URL: http://finquest-api:8080
      FINQUEST_WEB_ORIGIN: ${FINQUEST_WEB_ORIGIN:-http://localhost:3000}
      AUTH_COOKIE_SECURE: ${AUTH_COOKIE_SECURE:-false}
    ports:
      - "${WEB_HOST_PORT:-3000}:3000"
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://localhost:3000/healthz').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 10s

  finquest-worker-market:
    build:
      context: .
      dockerfile: Dockerfile
      target: base
    container_name: finquest-worker-market
    restart: unless-stopped
    networks: [finquest-net]
    depends_on:
      stock-db:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment: &worker-env
      DATABASE_URL: postgresql+asyncpg://stock_user:stock_password@stock-db:5432/stock_research
      AUTH_JWT_SECRET: ${AUTH_JWT_SECRET:?AUTH_JWT_SECRET must be set - see README}
      EMBEDDING_PROVIDER: ${EMBEDDING_PROVIDER:-deterministic_fake}
      FINQUEST_ENV: ${FINQUEST_ENV:-development}
      ALLOW_FAKE_EMBEDDINGS_IN_PRODUCTION: ${ALLOW_FAKE_EMBEDDINGS_IN_PRODUCTION:-false}
      REDIS_URL: redis://redis:6379/0
      CELERY_BROKER_URL: redis://redis:6379/0
      CELERY_RESULT_BACKEND: redis://redis:6379/1
      CELERY_WORKER_PREFETCH_MULTIPLIER: "1"
      CELERY_TASK_ACKS_LATE: "true"
      METRICS_ENABLED: ${METRICS_ENABLED:-true}
    # Low bounded concurrency: each task makes outbound market-data-provider
    # calls, so this queue is I/O-bound but rate-sensitive against the
    # upstream provider.
    command: >
      celery -A stock_research_core.infrastructure.operations.celery_tasks worker
      --loglevel=info -Q finquest.market --concurrency=2 -n worker-market@%h
    healthcheck:
      test: ["CMD", "python", "-m", "stock_research_core.cli.worker_status"]
      interval: 30s
      timeout: 15s
      retries: 5
      start_period: 20s

  finquest-worker-portfolio:
    build:
      context: .
      dockerfile: Dockerfile
      target: base
    container_name: finquest-worker-portfolio
    restart: unless-stopped
    networks: [finquest-net]
    depends_on:
      stock-db:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment: *worker-env
    # Moderate bounded concurrency: valuation is CPU-light (pandas over
    # already-stored bars), so more headroom than market/knowledge.
    command: >
      celery -A stock_research_core.infrastructure.operations.celery_tasks worker
      --loglevel=info -Q finquest.portfolio --concurrency=4 -n worker-portfolio@%h
    healthcheck:
      test: ["CMD", "python", "-m", "stock_research_core.cli.worker_status"]
      interval: 30s
      timeout: 15s
      retries: 5
      start_period: 20s

  finquest-worker-knowledge:
    build:
      context: .
      dockerfile: Dockerfile
      # Override to `ai` (`docker compose build --build-arg` or edit this
      # line) for real sentence-transformer embeddings; `base` works fine
      # with the default deterministic_fake provider.
      target: ${KNOWLEDGE_WORKER_TARGET:-base}
    container_name: finquest-worker-knowledge
    restart: unless-stopped
    networks: [finquest-net]
    depends_on:
      stock-db:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment: *worker-env
    # Low concurrency: embeddings (real or fake) and chunking are
    # CPU/RAM-intensive per document. The evaluation queue is served by
    # this same worker (both are knowledge-base-adjacent, low-volume,
    # and neither needs its own dedicated process in this phase).
    command: >
      celery -A stock_research_core.infrastructure.operations.celery_tasks worker
      --loglevel=info -Q finquest.knowledge,finquest.evaluation --concurrency=1 -n worker-knowledge@%h
    healthcheck:
      test: ["CMD", "python", "-m", "stock_research_core.cli.worker_status"]
      interval: 30s
      timeout: 20s
      retries: 5
      start_period: 30s

  finquest-worker-default:
    build:
      context: .
      dockerfile: Dockerfile
      target: base
    container_name: finquest-worker-default
    restart: unless-stopped
    networks: [finquest-net]
    depends_on:
      stock-db:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment: *worker-env
    command: >
      celery -A stock_research_core.infrastructure.operations.celery_tasks worker
      --loglevel=info -Q finquest.default --concurrency=2 -n worker-default@%h
    healthcheck:
      test: ["CMD", "python", "-m", "stock_research_core.cli.worker_status"]
      interval: 30s
      timeout: 15s
      retries: 5
      start_period: 20s

volumes:
  stock_db_data:
