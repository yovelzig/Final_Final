DATABASE_URL=postgresql+asyncpg://stock_user:stock_password@localhost:5433/stock_research
TEST_DATABASE_URL=postgresql+asyncpg://stock_user:stock_password@localhost:5433/stock_research_test
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Phase 8: grounded AI tutor knowledge-base embeddings.
# EMBEDDING_PROVIDER=deterministic_fake is a dev/test-only option (no
# model download, no torch dependency) - see
# infrastructure.ai_tutor.deterministic_fake_embeddings.
EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# Phase 8: grounded AI tutor model provider.
# TUTOR_MODEL_PROVIDER=extractive (default) requires no API key and no
# network access. Set to openai_compatible to use a local Ollama /v1
# endpoint, vLLM, or a remote OpenAI-compatible provider.
TUTOR_MODEL_PROVIDER=extractive
TUTOR_MODEL_BASE_URL=http://localhost:11434/v1
TUTOR_MODEL_API_KEY=
TUTOR_MODEL_NAME=
TUTOR_MODEL_TIMEOUT_SECONDS=60

# Phase 9: FinQuest Product API.
API_TITLE=FinQuest API
API_VERSION=1.0.0
API_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8080
API_CORS_ORIGINS=http://localhost:3000
API_DOCS_ENABLED=true
API_RATE_LIMIT_ENABLED=true
API_LOGIN_RATE_LIMIT=10
API_LOGIN_RATE_WINDOW_SECONDS=60

# Phase 9: identity/authentication. AUTH_JWT_SECRET is REQUIRED - the API
# refuses to start without a strong (>=32 char) secret outside test mode.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=iPsVbBRJl2dPMD4F3Nm68dukscG2cL9pUhrK2nTc_Nw8U-27osCoJdLTyP7EkYZaEiGmhMZxCdQBZC5pk9pFhg
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ISSUER=finquest
AUTH_JWT_AUDIENCE=finquest-api
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15

# Phase 11: runtime environment and production embedding-provider safety.
# FINQUEST_ENV=production refuses to start with
# EMBEDDING_PROVIDER=deterministic_fake unless
# ALLOW_FAKE_EMBEDDINGS_IN_PRODUCTION is explicitly set to true.
FINQUEST_ENV=development
ALLOW_FAKE_EMBEDDINGS_IN_PRODUCTION=false

# Phase 11: Redis / Celery background jobs.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true

# Phase 11: metrics and optional OpenTelemetry tracing.
METRICS_ENABLED=true
METRICS_REQUIRE_AUTH=false
OTEL_ENABLED=false
OTEL_SERVICE_NAME=finquest-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATIO=0.1

# Phase 11: worker/Redis readiness gating for GET /ready.
READINESS_REQUIRE_WORKER=true
READINESS_REQUIRE_REDIS=true

# Phase 11: trusted-proxy-aware client identity (rate limiting +
# authentication audit). Leave TRUST_FORWARDED_HEADERS=false unless
# FastAPI sits behind a proxy on a private network you control -
# TRUSTED_PROXY_CIDRS should be scoped as narrowly as possible (never
# 0.0.0.0/0). Docker Compose sets both automatically, scoped to the
# private finquest-net bridge subnet.
TRUST_FORWARDED_HEADERS=false
TRUSTED_PROXY_CIDRS=

# Phase 12: LangGraph learning coach (personalized learning orchestrator).
# Disabled by default - no checkpointer connection, no compiled graph,
# and /api/v1/coach is not even registered unless this is true. Requires
# a one-time `python -m stock_research_core.cli.learning_orchestrator_admin
# --setup-checkpointer` before first use (never run automatically).
LANGGRAPH_ENABLED=false
LANGGRAPH_GRAPH_VERSION=learning-coach-graph-v1
LANGGRAPH_MAX_STEPS=30
LANGGRAPH_RUN_TIMEOUT_SECONDS=90
LANGGRAPH_MAX_REPAIR_ATTEMPTS=1
LANGGRAPH_MODEL_INTENT_CLASSIFICATION=false
LANGGRAPH_CHECKPOINTER_ENABLED=true
LANGGRAPH_CHECKPOINT_SCHEMA=langgraph
LANGGRAPH_THREAD_LOCK_TTL_SECONDS=120
LANGGRAPH_THREAD_LOCK_WAIT_SECONDS=2
LANGGRAPH_MAX_CONTEXT_CHARACTERS=20000
LANGGRAPH_MAX_STATE_LIST_ITEMS=50

# Phase 12: optional model-assisted intent-classification fallback -
# only ever consulted when the deterministic rule-based classifier
# returns UNKNOWN and LANGGRAPH_MODEL_INTENT_CLASSIFICATION=true.
LANGGRAPH_INTENT_MODEL_BASE_URL=
LANGGRAPH_INTENT_MODEL_API_KEY=
LANGGRAPH_INTENT_MODEL_NAME=

# Phase 12: optional LangSmith tracing - disabled by default, no
# account required, never fails a learner request if unavailable.
# LANGSMITH_TRACE_CONTENT=false hides learner input/output from traces.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finquest-learning-coach
LANGSMITH_TRACE_CONTENT=false

# Phase 13: quality-evaluation platform. DETERMINISTIC mode requires no
# evaluator LLM and no API key - it is the always-available default.
QUALITY_EVALUATION_MODE=DETERMINISTIC

# RAGAS mode is opt-in and independent of the production tutor's own
# model/provider - never reuses TUTOR_MODEL_* settings. Requires the
# `quality_evaluation` extra (`pip install -e ".[quality_evaluation]"`).
RAGAS_ENABLED=false
RAGAS_EVALUATOR_PROVIDER=openai_compatible
RAGAS_EVALUATOR_BASE_URL=
RAGAS_EVALUATOR_API_KEY=
RAGAS_EVALUATOR_MODEL=
RAGAS_EMBEDDING_PROVIDER=existing_finquest
RAGAS_MAX_CONCURRENCY=2
RAGAS_TIMEOUT_SECONDS=120
RAGAS_MAX_RETRIES=2
RAGAS_MAX_SAMPLES_PER_RUN=200
RAGAS_CACHE_ENABLED=true
# Reject same-model evaluation by default - the tutor's own model must
# not also grade itself unless explicitly overridden.
RAGAS_ALLOW_SAME_MODEL_AS_TUTOR=false

QUALITY_GATE_DEFAULT_ABSOLUTE_TOLERANCE=0.02
QUALITY_GATE_DEFAULT_RELATIVE_TOLERANCE=0.05

LEARNING_QUALITY_MIN_COHORT_SIZE=5
LEARNING_QUALITY_MIN_RETENTION_DAYS=7
LEARNING_QUALITY_MAX_RETENTION_DAYS=60

# Production startup must never silently enable copying real learner
# content into evaluation datasets.
QUALITY_ALLOW_PRODUCTION_SAMPLE_CAPTURE=false
