# =============================================================================
# FinQuest production environment template
# =============================================================================
# This file is safe to commit because it contains no real secrets.
# On the production server, copy it to `.env` and replace every required
# blank value. Never commit the real `.env` file.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Docker Compose constructs DATABASE_URL from these values.
# POSTGRES_PASSWORD must be generated separately on the production server.

POSTGRES_USER=stock_user
POSTGRES_PASSWORD=
POSTGRES_DB=stock_research

DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Required. Generate a unique value on the production server.
# Minimum length enforced by the application: 32 characters.

AUTH_JWT_SECRET=

AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ISSUER=finquest
AUTH_JWT_AUDIENCE=finquest-api
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15


# -----------------------------------------------------------------------------
# Production runtime
# -----------------------------------------------------------------------------

FINQUEST_ENV=production
ALLOW_FAKE_EMBEDDINGS_IN_PRODUCTION=false


# -----------------------------------------------------------------------------
# Public URLs
# -----------------------------------------------------------------------------
# Replace these example domains in the real server `.env`.
#
# FINQUEST_WEB_ORIGIN:
#   Public URL opened by the learner.
#
# NEXT_PUBLIC_FINQUEST_API_BASE_URL:
#   Public API URL used by the learner's browser. This value is baked into
#   the Next.js client bundle during `docker compose build`.

FINQUEST_WEB_ORIGIN=https://finquest.example.com
NEXT_PUBLIC_FINQUEST_API_BASE_URL=https://api.finquest.example.com

AUTH_COOKIE_SECURE=true

API_HOST_PORT=8080
WEB_HOST_PORT=3000


# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------

API_TITLE=FinQuest API
API_VERSION=1.0.0
API_PREFIX=/api/v1

API_DOCS_ENABLED=false
API_RATE_LIMIT_ENABLED=true
API_LOGIN_RATE_LIMIT=10
API_LOGIN_RATE_WINDOW_SECONDS=60


# -----------------------------------------------------------------------------
# Embeddings and knowledge retrieval
# -----------------------------------------------------------------------------
# Production must use a real provider.
# The Docker image must include the `ai_tutor` optional dependency.

EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32


# -----------------------------------------------------------------------------
# Grounded AI tutor
# -----------------------------------------------------------------------------
# `extractive` is network-free and requires no external model API.
# The optional OpenAI-compatible fields may remain blank in this mode.

TUTOR_MODEL_PROVIDER=extractive
TUTOR_MODEL_BASE_URL=
TUTOR_MODEL_API_KEY=
TUTOR_MODEL_NAME=
TUTOR_MODEL_TIMEOUT_SECONDS=60


# -----------------------------------------------------------------------------
# Redis and Celery
# -----------------------------------------------------------------------------
# Redis connection addresses are defined inside Docker Compose because they
# always use Docker's private service hostname `redis`.

CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true

READINESS_REQUIRE_WORKER=true
READINESS_REQUIRE_REDIS=true


# -----------------------------------------------------------------------------
# Metrics and tracing
# -----------------------------------------------------------------------------

METRICS_ENABLED=true
METRICS_REQUIRE_AUTH=true

OTEL_ENABLED=false
OTEL_SERVICE_NAME=finquest-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATIO=0.1


# -----------------------------------------------------------------------------
# LangGraph personalized learning coach
# -----------------------------------------------------------------------------
# Keep disabled for the first deployment.
#
# After migrations and the one-time checkpointer setup command succeed,
# change LANGGRAPH_ENABLED=true in the real server `.env` and restart the
# API container.

LANGGRAPH_ENABLED=false
LANGGRAPH_GRAPH_VERSION=learning-coach-graph-v1
LANGGRAPH_MAX_STEPS=30
LANGGRAPH_RUN_TIMEOUT_SECONDS=90
LANGGRAPH_MAX_REPAIR_ATTEMPTS=1

LANGGRAPH_MODEL_INTENT_CLASSIFICATION=false
LANGGRAPH_CHECKPOINTER_ENABLED=true
LANGGRAPH_CHECKPOINT_SCHEMA=langgraph
LANGGRAPH_THREAD_LOCK_TTL_SECONDS=120
LANGGRAPH_THREAD_LOCK_WAIT_SECONDS=2
LANGGRAPH_MAX_CONTEXT_CHARACTERS=20000
LANGGRAPH_MAX_STATE_LIST_ITEMS=50

LANGGRAPH_INTENT_MODEL_BASE_URL=
LANGGRAPH_INTENT_MODEL_API_KEY=
LANGGRAPH_INTENT_MODEL_NAME=


# -----------------------------------------------------------------------------
# Optional LangSmith tracing
# -----------------------------------------------------------------------------

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finquest-learning-coach
LANGSMITH_TRACE_CONTENT=false


# -----------------------------------------------------------------------------
# Quality evaluation
# -----------------------------------------------------------------------------

QUALITY_EVALUATION_MODE=DETERMINISTIC

RAGAS_ENABLED=false
RAGAS_EVALUATOR_PROVIDER=openai_compatible
RAGAS_EVALUATOR_BASE_URL=
RAGAS_EVALUATOR_API_KEY=
RAGAS_EVALUATOR_MODEL=
RAGAS_EMBEDDING_PROVIDER=existing_finquest
RAGAS_MAX_CONCURRENCY=2
RAGAS_TIMEOUT_SECONDS=120
RAGAS_MAX_RETRIES=2
RAGAS_MAX_SAMPLES_PER_RUN=200
RAGAS_CACHE_ENABLED=true
RAGAS_ALLOW_SAME_MODEL_AS_TUTOR=false

QUALITY_GATE_DEFAULT_ABSOLUTE_TOLERANCE=0.02
QUALITY_GATE_DEFAULT_RELATIVE_TOLERANCE=0.05

LEARNING_QUALITY_MIN_COHORT_SIZE=5
LEARNING_QUALITY_MIN_RETENTION_DAYS=7
LEARNING_QUALITY_MAX_RETENTION_DAYS=60

QUALITY_ALLOW_PRODUCTION_SAMPLE_CAPTURE=false